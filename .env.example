# Discord OAuth — create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
DISCORD_REDIRECT_URI=http://localhost:9200/auth/callback
DISCORD_ADMIN_ROLE=

# Discord Bot — create a bot at https://discord.com/developers/applications
# Bot needs "Send Messages" and "Read Messages" under Privileged Gateway Intents
DISCORD_BOT_TOKEN=
BOT_POLL_INTERVAL=30

PORT=9200
HOST=0.0.0.0
