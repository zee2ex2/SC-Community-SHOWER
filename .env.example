# Discord OAuth — create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
DISCORD_GUILD_NAME=
DISCORD_REDIRECT_URI=
DISCORD_ADMIN_ROLE=

# Discord Bot
DISCORD_BOT_TOKEN=
BOT_POLL_INTERVAL=30

# Server
PORT=9200
HOST=0.0.0.0
# WS_PORT=9201  # WebSocket port (optional, default: PORT+1)

# Database
# SHOWER_DB=/path/to/shower.db            # SQLite (default: shower_data/shower.db)
# SHOWER_DB=mysql://user:pass@host/db      # MySQL (requires pymysql)
# SHOWER_DB=Driver={ODBC Driver 18 for SQL Server};Server=tcp:host,1433;Database=db;Uid=user;Pwd=pass;Encrypt=yes;  # SQL Server (requires pyodbc)
